{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "command": "bash scripts/sync-claude-md.sh 2>/dev/null || true"
      }
    ],
    "onStop": [
      {
        "command": "bun scripts/check-deps-direction.ts 2>/dev/null || true"
      },
      {
        "command": "nexus doctor --quick 2>/dev/null || true"
      }
    ]
  }
}

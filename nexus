#!/bin/bash
# nexus â€” Automated project infrastructure
# https://github.com/teohondascully/nexus

set -e

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
NEXUS_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

source "$NEXUS_DIR/cli/helpers.sh"

cmd_help() {
  echo ""
  echo -e "  ${BOLD}nexus${NC} â€” invisible project infrastructure"
  echo ""
  echo -e "  Run ${BOLD}nexus init${NC} in any project. Then code like normal."
  echo -e "  Nexus handles maintenance behind the scenes."
  echo ""
  echo -e "  ${GREEN}nexus init${NC}           Set up a project"
  echo -e "  ${GREEN}nexus${NC}                Check project health (alias: doctor)"
  echo -e "  ${GREEN}nexus doctor --fix${NC}   Auto-fix what it can"
  echo -e "  ${GREEN}nexus update${NC}         Pull latest conventions"
  echo -e "  ${GREEN}nexus readme${NC}         How nexus works"
  echo -e "  ${GREEN}nexus version${NC}        Show version"
  echo -e "  ${GREEN}nexus uninstall${NC}      Remove nexus"
  echo ""
}

cmd_readme() {
  echo ""
  echo -e "  ${BOLD}nexus â€” invisible project infrastructure${NC}"
  echo ""
  echo -e "  There are two parts to what you installed:"
  echo ""
  echo -e "  ${BOLD}1. Dev environment${NC} ${DIM}(bootstrap)${NC}"
  echo ""
  echo -e "  The curl command set up your machine: a GPU-accelerated"
  echo -e "  terminal (Ghostty), modern replacements for ls/cat/grep/find,"
  echo -e "  language runtimes managed by mise, and Claude Code for"
  echo -e "  AI-assisted coding."
  echo ""
  echo -e "  These are just tools. They work independently. You could"
  echo -e "  uninstall nexus and keep all of them."
  echo ""
  echo -e "  ${BOLD}2. Project infrastructure${NC} ${DIM}(nexus)${NC}"
  echo ""
  echo -e "  nexus init detects your stack and sets up automated checks."
  echo -e "  Run it once per project, then code normally."
  echo ""
  echo -e "  The conventions it drops (CLAUDE.md, pre-commit hooks) are"
  echo -e "  built from 50+ architecture notes covering dependency design,"
  echo -e "  testing patterns, and security boundaries. Not boilerplate."
  echo ""
  echo -e "  ${BOLD}On every commit:${NC}"
  echo ""
  echo -e "    ${CYAN}Env sync${NC}          Fails if code uses env vars not in .env.example"
  echo -e "    ${CYAN}Import direction${NC}  Fails if imports break your dependency chain"
  echo -e "    ${CYAN}Dependency check${NC}  Fails if code imports packages not in your manifest"
  echo -e "    ${CYAN}File structure${NC}    Keeps CLAUDE.md file map accurate for AI agents"
  echo ""
  echo -e "  ${BOLD}On every AI coding session:${NC}"
  echo ""
  echo -e "    ${CYAN}Session start${NC}     Rebuilds project context so AI doesn't re-explore"
  echo -e "    ${CYAN}Session end${NC}       Health check catches drift before it compounds"
  echo ""
  echo -e "  ${BOLD}Commands${NC}"
  echo ""
  echo -e "    ${GREEN}nexus init${NC}           Set up a project"
  echo -e "    ${GREEN}nexus${NC}                Check project health"
  echo -e "    ${GREEN}nexus doctor --fix${NC}   Auto-fix what it can"
  echo -e "    ${GREEN}nexus update${NC}         Pull latest conventions"
  echo -e "    ${GREEN}nexus uninstall${NC}      Remove nexus"
  echo ""
  echo -e "  ${DIM}https://github.com/teohondascully/nexus${NC}"
  echo ""
}

case "${1:-}" in
  init)       shift; source "$NEXUS_DIR/cli/init.sh"; cmd_init "$@" ;;
  doctor)     shift; source "$NEXUS_DIR/cli/doctor.sh"; cmd_doctor "$@" ;;
  update)     source "$NEXUS_DIR/cli/update.sh"; cmd_update ;;
  readme)     cmd_readme ;;
  version)    echo "nexus v$(cat "$NEXUS_DIR/VERSION" 2>/dev/null || echo "unknown")" ;;
  uninstall)  exec bash "$NEXUS_DIR/install.sh" --uninstall ;;
  help|--help|-h) cmd_help ;;
  "")         source "$NEXUS_DIR/cli/doctor.sh"; cmd_doctor ;;
  *)          echo -e "  ${RED}Unknown: $1${NC}"; cmd_help ;;
esac
